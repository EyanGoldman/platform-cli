{
  "name": "@enterprise/platform-cli",
  "version": "0.1.0",
  "description": "Bootstrap CLI that gets a developer machine from 'nothing installed' to 'ready to build apps via Claude Code' against the platform proxy.",
  "private": true,
  "type": "module",
  "bin": {
    "platform": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/make-executable.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
